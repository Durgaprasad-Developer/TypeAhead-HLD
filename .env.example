# Copy this file to .env and fill in your Supabase credentials.
# Get the JDBC URL from: Supabase Dashboard → Connect → JDBC tab
# (use the Transaction Pooler URL for serverless-friendly pooling)

SUPABASE_DB_URL=jdbc:postgresql://<host>:6543/postgres?sslmode=require
SUPABASE_DB_USER=postgres.<project-ref>
SUPABASE_DB_PASSWORD=<your-db-password>
